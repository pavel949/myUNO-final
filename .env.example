# --- Database ---
# PostgreSQL connection string (Neon in production)
DATABASE_URL=postgresql://user:password@localhost:5432/myuno

# --- Test Database ---
# REQUIRED to run tests safely. Must be a separate database from DATABASE_URL.
# Tests will fail fast if this is not set, protecting the live database.
# For local dev: use a local Postgres instance; for CI: point to a test database.
DATABASE_URL_TEST=postgresql://test:test@localhost:5432/myuno_test

# --- Auth / sessions (REQUIRED in production) ---
# Signs session cookies. Generate with: openssl rand -base64 32
# NEXTAUTH_SECRET is accepted as a fallback name; SESSION_SECRET wins.
SESSION_SECRET=change-me-generate-with-openssl-rand
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand
# Base URL used in emailed links (verify, password reset)
NEXTAUTH_URL=http://localhost:3000

# --- PII encryption (REQUIRED in production) ---
# AES-256-GCM key for field-level encryption of passport data (PDPA, doc 12).
# Generate once with: openssl rand -hex 32
# CRITICAL: This key must be IDENTICAL in all environments (local, staging, production).
# If changed or lost once data is encrypted, all encrypted data becomes permanently unreadable.
# See docs/15_deployment.md §4 for full requirements.
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# --- Email (optional in dev: without it, emails log to the console) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# --- Scheduled jobs (REQUIRED in production) ---
# Bearer token protecting /api/cron/* routes; set the same value in Vercel.
# Generate with: openssl rand -hex 24
CRON_SECRET=change-me-generate-with-openssl-rand
